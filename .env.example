# Port exposed on the host (default: 9597)
PORT=9597

# UID/GID do usuário que roda o processo dentro do container
# Use `id -u` e `id -g` para pegar os valores do seu usuário no host
PUID=1000
PGID=1000

# PocketBase encryption key for pb_data at rest (optional but recommended in production)
# Generate with: openssl rand -hex 32
PB_ENCRYPTION_KEY=
