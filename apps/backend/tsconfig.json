{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "moduleDetection": "force",
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "strict": true,
    "skipLibCheck": true,
    "baseUrl": ".",
    "types": ["node"],
    "typeRoots": ["./node_modules/@types", "../web/node_modules/@types"],
    "paths": {
      "vitest": ["../web/node_modules/vitest"],
      "vitest/*": ["../web/node_modules/vitest/*"]
    }
  },
  "include": ["tests/**/*.ts"]
}
